      import itertools

def solve():
    # 1. Read K (number of lists) and M (modulo value)
    # Input format: K M
    try:
        line1 = input().split()
        if not line1: return
        k, m = map(int, line1)
    except EOFError:
        return

    # 2. Read each list and store the squares of its elements
    # Input format: N element1 element2 ...
    lists = []
    for _ in range(k):
        # We skip the first element (N) and take the rest
        row = list(map(int, input().split()))[1:]
        # Store the square of each element to simplify the final calculation
        lists.append([x**2 for x in row])

    # 3. Use itertools.product to find the maximum modulo sum
    # product(*lists) gives all combinations picking one from each list
    max_sum_mod = 0
    for combination in itertools.product(*lists):
        current_sum_mod = sum(combination) % m
        if current_sum_mod > max_sum_mod:
            max_sum_mod = current_sum_mod

    # 4. Output the result
    print(max_sum_mod)

