from collections import defaultdict

def solve():
    try:
        # Read the sizes of groups A and B
        n_m = list(map(int, input().split()))
        if not n_m:
            return
        n, m = n_m[0], n_m[1]
        
        # Create a defaultdict to store indices of words in group A
        # The default factory is list, so if a key is missing, it creates an empty list
        d = defaultdict(list)
        
        # Populate group A and the dictionary with 1-based indices
        for i in range(1, n + 1):
            word = input().strip()
            if word:
                d[word].append(str(i)) # Store indices as strings for easier joining later

        # Process words in group B
        for _ in range(m):
            word = input().strip()
            if word:
                if word in d:
                    # Join the list of indices with spaces
                    print(" ".join(d[word]))
                else:
                    # Print -1 if the word is not found in group A
                    print("-1")
    except EOFError:
        pass
    except ValueError:
        pass

